# RS Digital Hub - Apache Configuration

# Prevent directory listing
Options -Indexes

# Default index files
DirectoryIndex index.php index.html

# Force HTTPS (uncomment on live server with SSL)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect sensitive files
<FilesMatch "(database|\.env|config|db|DEPLOY)\.(sql|ini|php|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to migrations directory
<IfModule mod_rewrite.c>
    RewriteRule ^migrations/ - [F,L]
    RewriteRule ^lib/tcpdf/ - [F,L]
</IfModule>

# PHP settings
<IfModule mod_php.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
